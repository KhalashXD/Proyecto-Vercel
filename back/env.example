# ============================================================
# Emergency Management System - Environment Configuration
# ============================================================

# IMPORTANTE: Copiar este archivo a .env y actualizar los valores
# DO NOT use these defaults in production!

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_USER=emergencyuser
DB_PASSWORD=emergencypass
DB_NAME=emergency_management
DB_HOST=database
DB_PORT=5432

# ============================================================
# BACKEND CONFIGURATION
# ============================================================
FLASK_ENV=development
FLASK_DEBUG=1
BACKEND_PORT=5000
SECRET_KEY=your-secret-key-change-in-production-12345
JWT_SECRET=your-jwt-secret-key-change-in-production-67890
LOG_LEVEL=INFO

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
NODE_ENV=development
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# ============================================================
# GOOGLE MAPS API
# ============================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================================
# REDIS CONFIGURATION (Optional)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# PGADMIN CONFIGURATION
# ============================================================
PGADMIN_EMAIL=admin@emergency.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_FILE=/app/logs/emergency.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
APP_NAME=Emergency Management System
APP_VERSION=1.0.0
APP_TIMEZONE=America/Santiago
APP_LOCALE=es_CL

# ============================================================
# SECURITY CONFIGURATION
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
JWT_EXPIRATION_HOURS=24
SESSION_TIMEOUT_MINUTES=30

# ============================================================
# SMTP CONFIGURATION (For Email Notifications - Optional)
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@emergency.local

# ============================================================
# PERFORMANCE CONFIGURATION
# ============================================================
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CONNECTION_POOL_SIZE=10

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_TELEGRAM_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEBSOCKET=true
ENABLE_API_DOCS=true

# ============================================================
# GEOLOCATION CONFIGURATION
# ============================================================
GEOLOCATION_PROVIDER=google
DEFAULT_LATITUDE=-33.0234
DEFAULT_LONGITUDE=-71.5543
MAP_ZOOM_LEVEL=13

# ============================================================
# BACKUP CONFIGURATION
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups
